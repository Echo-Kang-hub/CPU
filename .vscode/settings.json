{
    // Digital IDE (sterben.fpga-support) linter 配置
    // 内置 LSP 语义分析会对合法 Verilog（前向引用、非 ANSI parameter 位置）误报
    // 将 linter.mode 设为 "shutdown" 以彻底关闭，避免假报错
    "digital-ide.function.lsp.linter.mode": "shutdown",

    // iverilog linter: -y . 让 iverilog 在当前目录按模块名搜索 .v 文件
    // 这样 sccomp_tb.v 引用 sccomp 时能找到 sccomp.v，消除 missing module 误报
    "verilog.linting.iverilog.arguments": "-y ."
}
